# Variables de entorno para Fynix (copia a .env.local)

# Supabase
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=

# PayPal — developer.paypal.com → Apps & Credentials
NEXT_PUBLIC_PAYPAL_CLIENT_ID=
PAYPAL_CLIENT_ID=
PAYPAL_CLIENT_SECRET=

# sandbox (pruebas) o live (producción)
PAYPAL_MODE=sandbox

# Opcional: Plan ID creado en PayPal Dashboard → Subscriptions
# Si no lo pones, Fynix crea el plan automáticamente (US$2.99/mes)
PAYPAL_PLAN_ID=

# Webhook — PayPal Dashboard → Webhooks → tu URL /api/paypal/webhook
PAYPAL_WEBHOOK_ID=

# Opcional: URL pública de la app (producción)
# NEXT_PUBLIC_APP_URL=https://tu-dominio.com
