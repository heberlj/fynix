# Variables de entorno para Fynix (copia a .env.local)

# Supabase
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=

# PayPal — developer.paypal.com → Apps & Credentials
NEXT_PUBLIC_PAYPAL_CLIENT_ID=
PAYPAL_CLIENT_ID=
PAYPAL_CLIENT_SECRET=

# sandbox (pruebas) o live (pagos reales)
PAYPAL_MODE=live

# Opcional: Plan ID creado en PayPal Dashboard → Subscriptions
# Si no lo pones, Fynix crea el plan automáticamente (US$2.99/mes)
PAYPAL_PLAN_ID=

# Webhook — PayPal Dashboard → Webhooks → tu URL /api/paypal/webhook
# Eventos: CHECKOUT.ORDER.*, PAYMENT.CAPTURE.COMPLETED, PAYMENT.SALE.COMPLETED
PAYPAL_WEBHOOK_ID=

# Necesario para activar Pro automáticamente al pagar (Supabase → Settings → API)
SUPABASE_SERVICE_ROLE_KEY=

# Ejecuta también: supabase/paypal-pagos-pendientes.sql

# Enlace de pago rápido (PayPal Dashboard → Payment Links / Enlace de pago)
NEXT_PUBLIC_PAYPAL_PAYMENT_LINK=https://www.paypal.com/ncp/payment/TU_ENLACE

# URL pública de la app (producción o local para pruebas PayPal)
NEXT_PUBLIC_APP_URL=http://localhost:3000
NEXT_PUBLIC_PAYPAL_MODE=live
